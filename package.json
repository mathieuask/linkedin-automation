{
  "name": "linkedin-automation",
  "version": "2.0.0",
  "description": "LinkedIn outreach automation with residential IP tunnel",
  "type": "commonjs",
  "main": "src/main.js",
  "scripts": {
    "test": "node tests/index.test.js",
    "start": "node src/main-browser.js",
    "start:api": "node src/main.js",
    "dev": "node --watch src/main-browser.js",
    "test:cookie": "node src/utils/validator.js",
    "test:browser": "node -e \"import('./src/browser.js').then(b => b.launchBrowser())\"",
    "test:fingerprint": "node scripts/check-fingerprint.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@notionhq/client": "^2.2.14",
    "dotenv": "^16.3.1",
    "impit": "^0.10.1",
    "node-fetch": "^2.7.0",
    "patchright": "^1.58.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^7.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "your-github-username",
