# ═══════════════════════════════════════════════════════════════════════════
# LinkedIn Automation - Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# 
# Copier ce fichier vers .env et remplir les valeurs :
#   cp .env.example .env
#   nano .env
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# LINKEDIN CREDENTIALS
# ─────────────────────────────────────────────────────────────────────────────
# Extraire depuis Chrome: F12 → Application → Cookies → linkedin.com
#
# li_at : Token principal (~1 an de validité)
LI_AT=AQEDAUce90gF...votre_token_complet

# JSESSIONID : Token CSRF (SANS les guillemets autour)
# Si le cookie affiche "ajax:12345", mettre ajax:12345
JSESSIONID=ajax:1234567890123456789

# ─────────────────────────────────────────────────────────────────────────────
# NOTION
# ─────────────────────────────────────────────────────────────────────────────
# Token d'intégration Notion (commençant par ntn_)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base de données Prospects/Deals
NOTION_DATABASE_ID=your-deals-database-id
NOTION_DEALS_DB_ID=your-deals-database-id

# ID de la base de données Contenu (posts LinkedIn)
NOTION_CONTENT_DB_ID=your-content-database-id

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM (Alertes)
# ─────────────────────────────────────────────────────────────────────────────
# Token du bot (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Chat ID (obtenu via https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─────────────────────────────────────────────────────────────────────────────
# USER PROFILE (Pour les prompts AI)
# ─────────────────────────────────────────────────────────────────────────────
# Nom utilisé dans les prompts de génération de messages
USER_NAME=YourName
# Âge utilisé dans les prompts
USER_AGE=XX
# Nom de l'entreprise
COMPANY_NAME=YourCompany

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
# Limites quotidiennes et hebdomadaires
# Recommandé: 15/jour, 80/semaine pour compte établi
DAILY_MAX=15
WEEKLY_MAX=80

# ─────────────────────────────────────────────────────────────────────────────
# TIMING (optionnel)
# ─────────────────────────────────────────────────────────────────────────────
# Paramètres des délais gaussiens (en minutes)
DELAY_MEAN=5
DELAY_STDDEV=1.5
DELAY_MIN=2
DELAY_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# HEALTHCHECK (optionnel)
# ─────────────────────────────────────────────────────────────────────────────
# URL healthchecks.io pour monitoring externe
# HEALTHCHECK_URL=https://hc-ping.com/your-uuid-here

# ─────────────────────────────────────────────────────────────────────────────
# MESSAGE PAR DÉFAUT (optionnel)
# ─────────────────────────────────────────────────────────────────────────────
# Message si aucun template dans Notion (300 chars max)
# Variables: {{firstName}}, {{company}}
# DEFAULT_MESSAGE=Bonjour {{firstName}}, je travaille sur des apps React Native et j'ai vu votre profil. Seriez-vous ouvert à échanger ?
